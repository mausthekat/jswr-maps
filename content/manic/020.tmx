 <objectgroup id="8" name="Special">
  <object id="23" x="96" y="8" width="16" height="16">
   <properties>
    <property name="Action" propertytype="Action" value="Complete"/>
    <property name="Comment" value="Latch fired externally by the SP Manic-Miner scorer when every collectible in the map has been picked up. Gates the entire end-game chain (celebration / swordfish / suit-revert / EndGame)."/>
    <property name="Name" value="items_done"/>
    <property name="TriggerType" propertytype="TriggerType" value="ExternalEvent"/>
   </properties>
  </object>
  <object id="24" x="152" y="56" width="16" height="16">
   <properties>
    <property name="Action" propertytype="Action" value="TeleportPlayerTo"/>
    <property name="Comment" value="THIS is the trigger that performs the end-game teleport. Once 'items_done' is satisfied (every collectible picked up), walking into this 16x16 region teleports Willy onto the plinth (object 25) and fires the 'celebration' latch that the rest of the chain (swordfish, hide-exits, suit-revert, delay, EndGame) hangs off."/>
    <property name="DependsOnCompletion" value="items_done"/>
    <property name="Name" value="celebration"/>
    <property name="Target" type="object" value="25"/>
    <property name="TriggerType" propertytype="TriggerType" value="CollisionWith"/>
   </properties>
  </object>
  <object id="25" template="templates/spawn_player.tx" x="160" y="32"/>
  <object id="26" gid="2271" x="152" y="56" width="16" height="16">
   <properties>
    <property name="Action" propertytype="Action" value="ShowEntity"/>
    <property name="Comment" value="Reveals the celebratory swordfish sprite on the plinth after the teleport. TriggeringPlayer visibility so only the finishing player sees it; spectators still see the pre-end-game room."/>
    <property name="DependsOnCompletion" value="celebration"/>
    <property name="Name" value="swordfish"/>
    <property name="TriggerType" propertytype="TriggerType" value="GameStart"/>
    <property name="Visibility" propertytype="Visibility" value="TriggeringPlayer"/>
   </properties>
  </object>
  <object id="27" x="152" y="56" width="16" height="16">
   <properties>
    <property name="Action" propertytype="Action" value="HideEntity"/>
    <property name="Comment" value="Untargeted HideEntity - hides the Manic Miner exit tiles in this room so the celebration tableau isn't cluttered with the live exit graphics. Visible only to the finishing player."/>
    <property name="DependsOnCompletion" value="celebration"/>
    <property name="TriggerType" propertytype="TriggerType" value="GameStart"/>
    <property name="Visibility" propertytype="Visibility" value="TriggeringPlayer"/>
   </properties>
  </object>
  <object id="28" x="120" y="24" width="8" height="8">
   <properties>
    <property name="Action" propertytype="Action" value="Delay"/>
    <property name="Comment" value="10-second pause after the teleport so the player gets to enjoy the celebration before the game ends. Threshold is in seconds; EndGame (id 29) waits on this latch."/>
    <property name="DependsOnCompletion" value="celebration"/>
    <property name="Name" value="wait"/>
    <property name="Threshold" type="int" value="10"/>
    <property name="TriggerType" propertytype="TriggerType" value="GameStart"/>
   </properties>
  </object>
  <object id="29" x="136" y="24" width="8" height="8">
   <properties>
    <property name="Action" propertytype="Action" value="EndGame"/>
    <property name="Comment" value="Fires at the end of the 10-second celebration delay. Ends the run and transitions everyone back to the lobby / scoreboard."/>
    <property name="DependsOnCompletion" value="wait"/>
    <property name="TriggerType" propertytype="TriggerType" value="GameStart"/>
   </properties>
  </object>
  <object id="30" x="120" y="8" width="8" height="8">
   <properties>
    <property name="Action" propertytype="Action" value="SetWillySuit"/>
    <property name="Comment" value="During gameplay this room sets WillySuit=Miner via the room property. After the teleport we override it back to Normal so Willy stands on the plinth as his default self for the celebration. Override clears automatically on room change or respawn."/>
    <property name="DependsOnCompletion" value="celebration"/>
    <property name="TriggerType" propertytype="TriggerType" value="GameStart"/>
    <property name="Visibility" propertytype="Visibility" value="TriggeringPlayer"/>
    <property name="WillySuit" type="int" propertytype="WillySuit" value="0"/>
   </properties>
  </object>
